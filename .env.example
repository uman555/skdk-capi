# ====================================
# Notion 集成凭证
# ====================================
# 1. 创建 Integration: https://www.notion.so/my-integrations
NOTION_INTEGRATION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. 数据库 ID（在 Notion 数据库 URL 中）
# URL 格式: https://www.notion.so/xxx/32位字符?v=...
# 32位字符（去掉横线）就是 Database ID
NOTION_DATABASE_ID=389cae2a241f800c9916c92b5e65e396

# ====================================
# Meta 凭证
# ====================================
# 3. 数据集 ID（在 Meta Events Manager 中）
# 创建方式: https://business.facebook.com/events_manager
# 点击"连接数据源" → "Web" → "Meta Pixel"
META_DATASET_ID=1723656532148251

# 4. Meta 应用 ID
# 创建方式: https://developers.facebook.com/apps/
# 创建"业务"类型应用
META_APP_ID=1554011292941689

# 5. Meta 访问令牌
# ⚠️ 重要：使用 System User Token（永不过期）
# 路径: business.facebook.com/settings/system-users
# 创建 System User → 分配资产 → 生成令牌
# 短期测试: developers.facebook.com/tools/explorer/（1-2h 过期）
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx

# ====================================
# 可选配置
# ====================================
# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 时区
TIMEZONE=Asia/Shanghai

# Railway 端口（自动设置，无需手动配置）
# PORT=5000
